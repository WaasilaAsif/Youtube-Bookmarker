{   "manifest_version": 3,
    "name": "Youtube Bookmarker",
    "version": "1.0",
    "description": "A Chrome extension that allows users to bookmark YouTube videos and manage their bookmarks.",
    
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "host permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts" : [
        {
            "matches" : ["https://*.youtube.com/*"],
            "js" : ["contentScript.js"]
        }

    ],
    "web_accessible_resources": [
        {
            "resources" : [
                "assets/bookmark.png",
                "assets/play.png",
                "assets/delete.png",
                "assets/save.png"
            ],
            "matches" : ["https://*.youtube.com/*"]

        }

    ],

    "action" : {
        "default_icon" : {
            "16" : "assets/bookmark.png",
            "48" : "assets/bookmark.png",
            "128" : "assets/bookmark.png"
        },
        "default_title" : "Youtube Bookmarker",
        "default_popup" : "popup.html"
    }

}