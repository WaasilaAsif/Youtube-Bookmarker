{   "manifest_version": 3,
    "name": "Youtube Bookmarker",
    "version": "1.0",
    "description": "A Chrome extension that allows users to bookmark YouTube videos and manage their bookmarks.",
    
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts" : [
        {
            "matches" : ["https://*.youtube.com/*"],
            "js" : ["contentScript.js"]
        }

    ],
    "web_accessible_resources": [
        {
            "resources" : [
                
            ],
            "matches" : ["https://*.youtube.com/*"]

        }

    ],
    "action" : {
        
        "default_title" : "Youtube Bookmarker",
        "default_popup" : "popup.html"
    }

}